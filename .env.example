# Canvas Server
PORT=8787

# fal provider. Get a key at https://fal.ai/dashboard/keys
FAL_KEY=

# KIE AI provider. Get a key at https://kie.ai (API Key Management).
# Powers kie/nano-banana-2 (image) and kie/kling-3.0 (video).
KIE_API_KEY=
# Optional override of the KIE API base host.
# KIE_API_BASE=https://api.kie.ai

# Set to 1 to use the mock provider (no API calls, no cost) — generates
# placeholder images/videos so the whole pipeline can be exercised offline.
MOCK_PROVIDER=0

# MCP server points at the Canvas Server
CANVAS_SERVER_URL=http://localhost:8787

# xAI Grok Imagine. Get a key at https://console.x.ai/
XAI_API_KEY=
